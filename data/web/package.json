{
  "name": "quick-dra",
  "description": "Webcomponent quick-dra following open-wc recommendations",
  "license": "MIT",
  "author": "quick-dra",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "type-check": "tsc --noEmit",
    "dep-check": "depcheck --quiet --ignores rimraf,babel-plugin-template-html-minifier",
    "vfs-check": "yarn build && python ../../tools/check-vfs.py",
    "lint": "eslint",
    "prettier": "prettier \"**/*.ts\" --check --ignore-path .gitignore",
    "format": "eslint --fix && prettier \"**/*.ts\" --write --ignore-path .gitignore",
    "build:dist": "rimraf dist && tsc && rollup -c rollup.config.js && npm run analyze -- --exclude dist",
    "build": "yarn build:dist && python ../../tools/webapp-vfs.py --no-build",
    "start:build": "web-dev-server --root-dir dist --app-index index.html --open",
    "analyze": "cem analyze --litelement",
    "start": "tsc && concurrently -k -r \"tsc --watch --preserveWatchOutput\" \"web-dev-server\""
  },
  "dependencies": {
    "@material/web": "^2.4.1",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@web/dev-server": "^0.4.6",
    "@web/rollup-plugin-html": "^3.1.0",
    "@web/rollup-plugin-import-meta-assets": "^2.3.3",
    "babel-plugin-template-html-minifier": "^4.1.0",
    "concurrently": "^9.2.1",
    "depcheck": "^1.4.7",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-lit": "^2.2.1",
    "globals": "^17.5.0",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.1",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-esbuild": "^6.2.1",
    "rollup-plugin-workbox": "^8.1.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2"
  },
  "prettier": {
    "singleQuote": true,
    "arrowParens": "avoid"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "customElements": "custom-elements.json",
  "packageManager": "yarn@4.13.0"
}
