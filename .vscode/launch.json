    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Quick-DRA GUI",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/quick-dra",
            "args": [ ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [ ],
            "externalConsole": false,
            "windows": {
                "type": "cppvsdbg"
            },
            "linux": {
                "type": "cppdbg",
                "MIMode": "gdb",
                "setupCommands": [
                    {
                        "description": "Enable pretty-printing for gdb",
                        "text": "-enable-pretty-printing",
                        "ignoreFailures": true
                    }
                ]
            },
            "preLaunchTask": "Build Debug with proj-flow"
        }
    ]
}